# Copy to .env and fill in. For local dev, use local PostgreSQL + schema oddscast.

# PostgreSQL — 로컬 Docker: docker compose up -d postgres 후 아래 그대로 사용 가능
DATABASE_URL="postgresql://oddscast:oddscast@localhost:5432/oddscast?schema=oddscast"
# 직접 설치한 경우: postgresql://USER:PASSWORD@localhost:5432/oddscast?schema=oddscast

# 서버 포트
PORT=3001

# JWT (openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Optional
# GEMINI_API_KEY=
# KRA_SERVICE_KEY=

# Discord Bot Notifications (optional — production)
# DISCORD_BOT_TOKEN=
# DISCORD_SIGNUP_CHANNEL_ID=
# DISCORD_ERROR_CHANNEL_ID=

# Discord Error Webhook (optional — production error alerts via webhook)
# DISCORD_ERROR_WEBHOOK_URL=

# Discord Dev Webhook (optional — non-production error alerts)
# DISCORD_DEV_WEBHOOK_URL=

# Kakao OAuth (https://developers.kakao.com — REST API 키 사용)
# KAKAO_CLIENT_ID=your_kakao_rest_api_key
# KAKAO_CLIENT_SECRET=your_kakao_client_secret_optional
# KAKAO_CALLBACK_URL=http://localhost:3001/api/auth/kakao/callback
# WEBAPP_URL=http://localhost:3000
