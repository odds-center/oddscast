{
  "name": "goldenrace",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "setup-env": "node scripts/setup-env.mjs",
    "setup-env:force": "node scripts/setup-env.mjs --force",
    "setup-env:generate": "node scripts/setup-env.mjs --generate",
    "setup-env:interactive": "node scripts/setup-env.mjs --interactive",
    "dev:server": "pnpm --filter server dev",
    "dev:webapp": "pnpm --filter webapp dev",
    "dev:admin": "pnpm --filter goldenrace-admin dev",
    "build": "pnpm run build:server && pnpm run build:webapp && pnpm run build:admin",
    "build:server": "pnpm --filter server build",
    "build:webapp": "pnpm --filter webapp build",
    "build:admin": "pnpm --filter goldenrace-admin build"
  },
  "description": "Golden Race monorepo — pnpm 워크스페이스"
}
