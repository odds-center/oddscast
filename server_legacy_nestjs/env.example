# ============================================
# Golden Race Server - 환경변수 설정 템플릿
# ============================================
# 사용법: 이 파일을 복사하여 .env 파일을 만들고 실제 값으로 변경하세요
# cp env.example .env

# ============================================
# 🚀 서버 기본 설정
# ============================================
NODE_ENV=development
PORT=3002

# ============================================
# 🗄️ Supabase PostgreSQL 데이터베이스 설정
# ============================================
# 옵션 1: Connection String 사용 (권장)
# Supabase 대시보드 → Settings → Database → Connection string에서 복사
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# 옵션 2: 개별 환경변수 사용
SUPABASE_DB_HOST=db.[PROJECT-REF].supabase.co
SUPABASE_DB_PORT=5432
# 프로덕션에서는 Connection Pooling 사용 권장 (포트 6543)
# SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=[YOUR-PASSWORD]
SUPABASE_DB_NAME=postgres

# 데이터베이스 로깅 (개발 환경에서만 true)
DB_LOGGING=true
# 데이터베이스 자동 동기화 (개발 환경에서만 true, 프로덕션에서는 절대 사용 금지!)
DB_SYNC=false

# ============================================
# 🔐 인증 설정
# ============================================
# JWT 토큰 설정
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=90d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production

# Google OAuth 설정
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# ============================================
# 🏇 KRA API 설정
# ============================================
KRA_API_KEY=your-kra-api-key
KRA_TIMEOUT=10000
KRA_MAX_RETRIES=3
KRA_DAILY_LIMIT=10000
KRA_RATE_LIMIT=100

# ============================================
# 🌐 CORS 설정
# ============================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,exp://localhost:19000

# ============================================
# ⚙️ 배치 작업 설정
# ============================================
BATCH_ENABLED=true
BATCH_TIMEZONE=Asia/Seoul
BATCH_DAILY_SYNC_TIME=06:00

# ============================================
# 💾 캐시 설정
# ============================================
CACHE_TTL=3600
CACHE_MAX=100
CACHE_CHECK_PERIOD=600

# ============================================
# 🔴 Redis 설정 (선택사항)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# 💳 결제 설정 (Toss Payments)
# ============================================
TOSS_SECRET_KEY=your-toss-secret-key
TOSS_CLIENT_KEY=your-toss-client-key

# ============================================
# 🤖 AI 설정 (선택사항)
# ============================================
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# 📝 로그 설정
# ============================================
LOG_LEVEL=info

# ============================================
# 📚 Swagger 설정
# ============================================
SWAGGER_ENABLED=true

