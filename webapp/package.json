{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:webpack": "next dev -p 3000 --webpack",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:integration": "node --env-file=.env.test ./node_modules/.bin/playwright test --config=playwright.integration.config.ts",
    "test:e2e:integration:ui": "node --env-file=.env.test ./node_modules/.bin/playwright test --config=playwright.integration.config.ts --ui"
  },
  "dependencies": {
    "@oddscast/shared": "file:../shared",
    "@sentry/nextjs": "^10.42.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "es-toolkit": "^1.38.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pretendard": "^1.3.9",
    "qs": "^6.14.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.53.0",
    "tailwind-merge": "^2.6.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/qs": "^6.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5"
  }
}
