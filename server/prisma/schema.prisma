generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 스키마 전략: prisma migrate 사용
// - prisma migrate dev: 개발 시 마이그레이션 생성/적용
// - prisma migrate deploy: 배포 시 마이그레이션 적용
// - 기존 db push로 운영 중이었다면: prisma migrate resolve --applied "마이그레이션명" 으로 baseline 처리 후 진행
// - prisma/seed.sql: 초기 데이터 (PointConfig, PointTicketPrice, SubscriptionPlan, GlobalConfig)
// ============================================

// ============================================
// 앱 사용자 (User) — 웹/모바일 회원
// ============================================
model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  name            String
  nickname        String?
  avatar          String?
  role            UserRole  @default(USER)
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  favorites              Favorite[]
  notifications          Notification[]
  notificationPreference UserNotificationPreference?
  pushTokens             PushToken[]
  predictionTickets      PredictionTicket[]
  subscriptions          Subscription[]
  billingHistories       BillingHistory[]
  singlePurchases        SinglePurchase[]
  pointTransactions      PointTransaction[]
  bets                   Bet[]
  picks                  UserPick[]
  betSlips               BetSlip[]
  passwordResetTokens   PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
}

// ============================================
// 비밀번호 재설정 토큰 (Auth)
// ============================================
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ============================================
// 이메일 인증 토큰 (Auth)
// ============================================
model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ============================================
// 관리자 (AdminUser) — Admin 패널 전용, User와 분리
// ============================================
model AdminUser {
  id          Int       @id @default(autoincrement())
  loginId     String    @unique // 로그인 아이디
  password    String
  name        String
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("admin_users")
}

enum UserRole {
  USER
  ADMIN // JWT/Guard용 (AdminUser는 DB에 role 없음)
}

// ============================================
// 경기 (Race) — KRA API 기준 (raceResult_3, entrySheet_2)
// ============================================
model Race {
  id          Int        @id @default(autoincrement())
  rcName      String? // KRA: 경주명
  meet        String // KRA: 시행경마장명 (서울, 제주, 부산경남)
  meetName    String?
  rcDate      String // KRA: YYYYMMDD
  rcDay       String? // KRA: 경주요일 (예: 일요일)
  rcNo        String // KRA: 경주번호
  stTime      String? // KRA: 출발시각
  rcDist      String? // KRA: 경주거리 (m)
  rank        String? // KRA: 등급조건 (예: 국6등급)
  rcCondition String?
  rcPrize     Int? // KRA: 1착상금 (경주 단위)
  weather     String? // KRA: 날씨
  track       String? // KRA: 주로상태 (예: 건조 (2%))
  status      RaceStatus @default(SCHEDULED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  entries     RaceEntry[]
  results     RaceResult[]
  predictions Prediction[]
  bets        Bet[]
  picks       UserPick[]
  betSlips    BetSlip[]

  @@unique([meet, rcDate, rcNo])
  @@map("races")
}

enum RaceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// 출전마 (RaceEntry) — KRA API 기준 (entrySheet_2)
// ============================================
model RaceEntry {
  id       Int     @id @default(autoincrement())
  raceId   Int
  hrNo     String // KRA: 마번(고유번호)
  hrName   String // KRA: 마명
  hrNameEn String? // KRA: 영문마명
  jkNo     String? // KRA: 기수번호
  jkName   String // KRA: 기수명
  jkNameEn String? // KRA: 영문기수이름
  trNo     String? // KRA: 조교사번호
  trName   String? // KRA: 조교사명
  owNo     String? // KRA: 마주번호
  owName   String? // KRA: 마주명

  wgBudam Float? // KRA: 부담중량 (kg)
  rating  Float? // KRA: 레이팅

  chulNo String? // KRA: 마번(출주번호) — 출전번호
  dusu   Int? // KRA: 두수 (총 출전 두수)

  sex String? // KRA: 성별 (암/수/거)
  age Int? // KRA: 연령
  prd String? // KRA: 산지 (예: 한국)

  // KRA: 상금·통산 성적
  chaksun1 Int? // KRA: 1착상금
  chaksunT BigInt? // KRA: 통산수득상금
  rcCntT   Int? // KRA: 통산출주횟수
  ord1CntT Int? // KRA: 통산1위횟수

  // 분석용 (Group B)
  budam         String? // KRA: 부담구분 (예: 별정A)
  ratingHistory Json? // KRA API77: 레이팅 추이 [rating2, rating3, rating4]. rating=rating1
  recentRanks   Json? // 최근 등수 배열
  trainingData Json? // 훈련 내역 (JSON)
  equipment    String? // 장구 변경 (KRA API24)
  horseWeight  String? // 마체중 (KRA API25, e.g. "502(-2)")
  bleedingInfo Json? // 폐출혈 이력
  isScratched  Boolean @default(false) // KRA API9: 출전취소

  // API37_1 마필 구간별 경주기록 (S1F, G3F, G1F 최고/최저/평균)
  sectionalStats Json?

  // Relations
  race      Race       @relation(fields: [raceId], references: [id], onDelete: Cascade)
  trainings Training[] // 1:N

  @@map("race_entries")
}

// ============================================
// 훈련 데이터 (Training) — KRA API 기준 (trcontihi)
// ============================================
model Training {
  id          Int    @id @default(autoincrement())
  raceEntryId Int?
  horseNo     String // KRA: 마번 (hrNo)

  trDate      String // KRA: 훈련일자 (YYYYMMDD)
  trTime      String? // KRA: 훈련시간
  trEndTime   String? // KRA: 훈련종료시간
  trDuration  String? // KRA: 훈련소요시간
  trContent   String? // KRA: 훈련조교내용
  trType      String? // KRA: 훈련종류 (발마, 조교 등)
  managerType String? // KRA: 관리사 종류
  managerName String? // KRA: 관리사명

  place          String? // KRA: 훈련장소
  weather        String? // KRA: 날씨
  trackCondition String? // KRA: 주로상태
  course         String? // 코스 (확장용)
  intensity      String? // 훈련 강도 (확장용)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  raceEntry RaceEntry? @relation(fields: [raceEntryId], references: [id])

  @@index([horseNo])
  @@index([trDate])
  @@map("trainings")
}

// ============================================
// 경주 결과 (RaceResult) — KRA API 기준 (raceResult_3)
// ============================================
model RaceResult {
  id      Int     @id @default(autoincrement())
  raceId  Int
  ord     String? // KRA: 순위
  ordInt  Int? // 정렬용 (ord 파싱, 10경주+ 대비)
  ordType String? // NORMAL(숫자)|FALL(낙마)|DQ(실격)|WITHDRAWN(기권). accuracy 계산 시 NORMAL/null만 actualTop 포함
  hrNo    String // KRA: 마번
  hrName  String // KRA: 마명
  chulNo  String? // KRA: 출전번호
  age     String? // KRA: 연령
  sex     String? // KRA: 성별 (수/암/거)
  jkNo    String? // KRA: 기수번호
  jkName  String? // KRA: 기수명
  trName  String? // KRA: 조교사명
  owName  String? // KRA: 마주명
  wgBudam Float? // KRA: 부담중량
  wgHr    String? // KRA: 마체감량 (e.g. 502(-2))
  hrTool  String? // KRA: 장구내역

  rcTime   String? // KRA: 경주기록 (초)
  diffUnit String? // KRA: 착차
  winOdds  Float? // KRA: 단승식배당율
  plcOdds  Float? // KRA: 복승식배당율

  track    String? // KRA: 주로상태 (해당 경주)
  weather  String? // KRA: 날씨 (해당 경주)
  chaksun1 Int? // KRA: 1착상금 (rcPrize)

  sectionalTimes Json? // 구간별 기록 (seS1fAccTime, seG3fAccTime 등)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@map("race_results")
}

// ============================================
// 기수 통산 전적 (JockeyResult)
// ============================================
model JockeyResult {
  id     Int    @id @default(autoincrement())
  meet   String // 1:서울, 2:제주, 3:부경
  jkNo   String // 기수번호
  jkName String // 기수명

  rcCntT   Int // 통산총출전횟수
  ord1CntT Int // 통산1착횟수
  ord2CntT Int // 통산2착횟수
  ord3CntT Int // 통산3착횟수

  winRateTsum Float // 승률
  quRateTsum  Float // 복승률

  chaksunT BigInt // 착순상금 (Total Prize)

  updatedAt DateTime @updatedAt

  @@unique([meet, jkNo])
  @@map("jockey_results")
}

// ============================================
// 조교사 통산 전적 (TrainerResult) — API19_1 trainerInfo_1
// ============================================
model TrainerResult {
  id     Int    @id @default(autoincrement())
  meet   String // 1:서울, 2:제주, 3:부경
  trNo   String // 조교사번호
  trName String // 조교사명

  rcCntT   Int // 통산총출전횟수
  ord1CntT Int // 통산1착횟수
  ord2CntT Int // 통산2착횟수
  ord3CntT Int // 통산3착횟수

  winRateTsum Float // 통산승률
  quRateTsum  Float // 통산복승률
  plRateTsum  Float? // 통산연승률 (1·2위 둘 다 들어올 확률)

  rcCntY   Int? // 최근1년 출주횟수
  ord1CntY Int? // 최근1년 1착횟수
  ord2CntY Int? // 최근1년 2착횟수
  ord3CntY Int? // 최근1년 3착횟수
  winRateY Float? // 최근1년 승률
  quRateY  Float? // 최근1년 복승률
  plRateY  Float? // 최근1년 연승률

  updatedAt DateTime @updatedAt

  @@unique([meet, trNo])
  @@map("trainer_results")
}

// ============================================
// AI 예측 (Prediction)
// ============================================
model Prediction {
  id              Int              @id @default(autoincrement())
  raceId          Int
  scores          Json? // { horseScores: [...] }
  analysis        String?          @db.Text // AI 분석글
  preview         String?          @db.Text // 무료 미리보기
  previewApproved Boolean          @default(false) // 검수 완료 시에만 preview 반환
  accuracy        Float?
  status          PredictionStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  race    Race               @relation(fields: [raceId], references: [id], onDelete: Cascade)
  tickets PredictionTicket[]

  @@map("predictions")
}

enum PredictionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// 예측권 (PredictionTicket)
// ============================================
model PredictionTicket {
  id             Int          @id @default(autoincrement())
  userId         Int
  subscriptionId Int?
  predictionId   Int?
  raceId         Int?
  type           TicketType   @default(RACE)
  status         TicketStatus @default(AVAILABLE)
  usedAt         DateTime?
  matrixDate     String?      /// MATRIX 타입 전용: 해당 날짜 (YYYYMMDD)
  issuedAt       DateTime     @default(now())
  expiresAt      DateTime

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  prediction   Prediction?   @relation(fields: [predictionId], references: [id])

  @@map("prediction_tickets")
}

enum TicketStatus {
  AVAILABLE
  USED
  EXPIRED
}

enum TicketType {
  RACE
  MATRIX
}

// ============================================
// 구독 플랜 (SubscriptionPlan)
// seed: LIGHT(10장/4,900원), STANDARD(20장/9,900원), PREMIUM(30장 27+3/14,900원), 1장=500원
// matrixTickets: 종합 예측권 — 5,000원당 1장 (LIGHT=0, STANDARD=1, PREMIUM=2)
// ============================================
model SubscriptionPlan {
  id            Int      @id @default(autoincrement())
  planName      String   @unique // LIGHT, STANDARD, PREMIUM
  displayName   String
  description   String?
  originalPrice Int
  vat           Int
  totalPrice    Int
  baseTickets   Int
  bonusTickets  Int      @default(0)
  totalTickets  Int
  matrixTickets Int      @default(0) /// 종합 예측권 수 (5,000원당 1장)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

// ============================================
// 구독 (Subscription)
// ============================================
model Subscription {
  id              Int                @id @default(autoincrement())
  userId          Int
  planId          Int
  price           Int
  status          SubscriptionStatus @default(PENDING)
  billingKey      String?
  nextBillingDate DateTime?
  lastBilledAt    DateTime?
  startedAt       DateTime           @default(now())
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan    SubscriptionPlan   @relation(fields: [planId], references: [id])
  tickets PredictionTicket[]

  @@map("subscriptions")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
}

// ============================================
// 알림 (Notification)
// ============================================
model Notification {
  id        Int                  @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType     @default(SYSTEM)
  category  NotificationCategory @default(GENERAL)
  isRead    Boolean              @default(false)
  data      Json? // 추가 데이터
  readAt    DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  SYSTEM
  RACE
  PREDICTION
  PROMOTION
  SUBSCRIPTION
}

enum NotificationCategory {
  GENERAL
  URGENT
  INFO
  MARKETING
}

// ============================================
// 푸시 토큰 (PushToken) — Expo Push 발송용
// ============================================
model PushToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String // ExponentPushToken[xxx]
  deviceId  String? // 앱에서 중복 등록 방지용
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@map("push_tokens")
}

// ============================================
// 알림 설정 (UserNotificationPreference)
// ============================================
model UserNotificationPreference {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  pushEnabled         Boolean  @default(true)
  raceEnabled         Boolean  @default(true) // 경주 시작/결과
  predictionEnabled   Boolean  @default(true) // AI 예측권/분석 관련
  subscriptionEnabled Boolean  @default(true) // 구독 결제/만료
  systemEnabled       Boolean  @default(true) // 시스템 공지
  promotionEnabled    Boolean  @default(false) // 프로모션/마케팅
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

// ============================================
// 즐겨찾기 (Favorite)
// ============================================
model Favorite {
  id              Int              @id @default(autoincrement())
  userId          Int
  type            FavoriteType
  targetId        String
  targetName      String
  targetData      Json?
  memo            String?
  priority        FavoritePriority @default(MEDIUM)
  tags            String[]         @default([])
  notificationsOn Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, targetId])
  @@map("favorites")
}

enum FavoriteType {
  HORSE
  JOCKEY
  TRAINER
  RACE
  MEET
}

enum FavoritePriority {
  LOW
  MEDIUM
  HIGH
}

// ============================================
// 결제 이력 (BillingHistory)
// ============================================
model BillingHistory {
  id              Int           @id @default(autoincrement())
  userId          Int
  amount          Int
  billingDate     DateTime      @default(now())
  status          PaymentStatus @default(SUCCESS)
  pgProvider      String?
  pgTransactionId String?
  errorMessage    String?
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billing_histories")
}

enum PaymentStatus {
  SUCCESS
  FAILED
  REFUNDED
}

// ============================================
// 개별 구매 (SinglePurchase)
// single_purchase_config: 500원/장, VAT포함 550원
// ============================================
model SinglePurchase {
  id              Int      @id @default(autoincrement())
  userId          Int
  quantity        Int      @default(1)
  totalAmount     Int
  paymentMethod   String?
  pgTransactionId String?
  purchasedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("single_purchases")
}

// ============================================
// 포인트 (Point)
// ============================================
model PointTransaction {
  id              Int                  @id @default(autoincrement())
  userId          Int
  transactionType PointTransactionType
  amount          Int
  balanceAfter    Int
  description     String
  status          PointStatus          @default(ACTIVE)
  metadata        Json?
  transactionTime DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

model PointPromotion {
  id          Int           @id @default(autoincrement())
  name        String
  description String
  type        PromotionType
  points      Int
  conditions  Json?
  startDate   DateTime
  endDate     DateTime
  maxUses     Int?
  currentUses Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("point_promotions")
}

enum PointTransactionType {
  EARNED
  SPENT
  REFUNDED
  BONUS
  PROMOTION
  ADMIN_ADJUSTMENT
  EXPIRED
  TRANSFER_IN
  TRANSFER_OUT
}

enum PointStatus {
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
  PROCESSING
}

enum PromotionType {
  SIGNUP_BONUS
  REFERRAL_BONUS
  DAILY_LOGIN
  SPECIAL_EVENT
  CUSTOM
}

// ============================================
// 베팅 (Bet)
// ============================================
model Bet {
  id              Int       @id @default(autoincrement())
  userId          Int
  raceId          Int
  betType         BetType
  betName         String
  betDescription  String?
  betAmount       Int
  potentialWin    Int?
  odds            Float?
  selections      Json // { horses: [], positions: [], combinations: [] }
  betStatus       BetStatus @default(PENDING)
  betResult       BetResult @default(PENDING)
  betTime         DateTime  @default(now())
  raceTime        DateTime?
  resultTime      DateTime?
  actualWin       Int?
  actualOdds      Float?
  confidenceLevel Float?
  betReason       String?
  analysisData    Json?
  apiVersion      String?
  dataSource      String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  roi             Float?
  riskLevel       String?
  isFavorite      Boolean   @default(false)
  notes           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@map("bets")
}

model BetSlip {
  id          Int           @id @default(autoincrement())
  raceId      Int
  userId      Int
  bets        Json // Array of bets
  totalAmount Int
  status      BetSlipStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@map("bet_slips")
}

enum BetType {
  WIN
  PLACE
  QUINELLA
  QUINELLA_PLACE
  EXACTA
  TRIFECTA
  TRIPLE
}

enum BetStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  WON
  LOST
}

enum BetResult {
  PENDING
  WIN
  LOSE
  PARTIAL_WIN
  VOID
}

enum BetSlipStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

// ============================================
// 내가 고른 말 (UserPick) — 승식별 기록, 적중 시 포인트
// ============================================
model UserPick {
  id            Int      @id @default(autoincrement())
  userId        Int
  raceId        Int
  pickType      PickType @default(SINGLE) // 단승/복승/연승/쌍승 등
  hrNos         String[] // 고른 마번 배열 [1, 5] or [1, 5, 7]
  hrNames       String[] // 마명 (표시용)
  pointsAwarded Int?     @default(0) // 적중 시 지급된 포인트
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@unique([userId, raceId])
  @@map("user_picks")
}

enum PickType {
  SINGLE // 단승식: 1마리 1등
  PLACE // 복승식: 1마리 1~3등
  QUINELLA // 연승식: 2마리 1·2등 (순서 무관)
  EXACTA // 쌍승식: 2마리 1·2등 (순서 유관)
  QUINELLA_PLACE // 복연승식: 2마리 3등 이내
  TRIFECTA // 삼복승식: 3마리 1·2·3등 (순서 무관)
  TRIPLE // 삼쌍승식: 3마리 1·2·3등 (순서 유관)
}

// ============================================
// 포인트 지급 설정 (PointConfig)
// ============================================
model PointConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique // BASE_POINTS, SINGLE_MULTIPLIER 등
  configValue String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("point_configs")
}

// ============================================
// 포인트 예측권 가격 (PointTicketPrice)
// seed: 1장=1200pt. Admin에서 수정 가능.
// ============================================
model PointTicketPrice {
  id              Int       @id @default(autoincrement())
  pointsPerTicket Int       @default(1200) // 1장당 포인트
  isActive        Boolean   @default(true)
  effectiveFrom   DateTime  @default(now())
  effectiveTo     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("point_ticket_prices")
}

// ============================================
// KRA API 동기화 로그 (각 API 호출 이력)
// ============================================
model KraSyncLog {
  id           Int      @id @default(autoincrement())
  endpoint     String // API 엔드포인트 (entrySheet, raceResult, jockey, trackInfo 등)
  meet         String? // 경마장 코드 (1/2/3)
  rcDate       String? // YYYYMMDD
  status       String // SUCCESS, FAILED, PARTIAL
  recordCount  Int      @default(0) // 처리된 레코드 수
  errorMessage String?  @db.Text
  durationMs   Int? // 소요 시간 (ms)
  createdAt    DateTime @default(now())

  @@index([endpoint, rcDate])
  @@index([createdAt])
  @@map("kra_sync_logs")
}

// ============================================
// Admin Activity Log — audit trail for admin actions
// ============================================
model AdminActivityLog {
  id          Int      @id @default(autoincrement())
  adminUserId Int?
  adminEmail  String?
  action      String   // e.g. SYNC_SCHEDULE, UPDATE_USER, GRANT_TICKETS
  target      String?  // e.g. "user:42", "race:20260215"
  details     Json?    // request body, params, or result summary
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_activity_logs")
}

// ============================================
// User Activity Log — user behavior tracking for analytics
// ============================================
model UserActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  sessionId String?
  event     String   // e.g. PAGE_VIEW, RACE_CLICK, PREDICTION_VIEW
  page      String?  // e.g. /races/123
  target    String?  // e.g. "race:123", "prediction:456"
  metadata  Json?    // extra context (scroll depth, referrer, etc.)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("user_activity_logs")
}

// ============================================
// 글로벌 설정 (Key-Value, NoSQL 스타일)
// seed: show_google_login, single_purchase_config(500원/장→550원 VAT포함)
// ============================================
model GlobalConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String // JSON 문자열 또는 단순 문자열
  updatedAt DateTime @updatedAt

  @@map("global_config")
}
