{
  "name": "goldenrace-server",
  "version": "1.0.0",
  "description": "Golden Race Express Server for KRA API integration",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest -i",
    "test:dev": "jest -i --no-cache --watch",
    "test:unit": "node ./src/test/setup.js && jest -i --no-cache -t ",
    "start": "node ./dist/index.js",
    "start:dev": "node ./dist/index.js",
    "start:local": "NODE_ENV=local node ./dist/index.js",
    "start:watch": "NODE_ENV=local tsx watch ./dist/index.js",
    "start:watch:build": "NODE_ENV=local tsx watch --exec \"npm run build && npm start\" src",
    "build": "mkdir -p ./dist/misc/email-templates && mkdir -p ./dist/public && [ -d ./src/misc/email-templates ] && [ \"$(ls -A ./src/misc/email-templates)\" ] && cp -r ./src/misc/email-templates/* ./dist/misc/email-templates/ || true && [ -d ./src/public ] && [ \"$(ls -A ./src/public)\" ] && cp -r ./src/public/* ./dist/public/ || true && tsc",
    "build:dev": "mkdir -p ./dist/misc/email-templates && mkdir -p ./dist/public && [ -d ./src/misc/email-templates ] && [ \"$(ls -A ./src/misc/email-templates)\" ] && cp -r ./src/misc/email-templates/* ./dist/misc/email-templates/ || true && [ -d ./src/public ] && [ \"$(ls -A ./src/public)\" ] && cp -r ./src/public/* ./dist/public/ || true && tsc --watch",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:debug": "ts-node-dev --respawn --transpile-only --inspect src/index.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only --poll src/index.ts",
    "dev:tsx": "tsx watch src/index.ts",
    "dev:tsx:build": "tsx watch --exec \"npm run build && npm start\" src",
    "dev:tsx:fast": "tsx watch --ignore-pattern node_modules src/index.ts",
    "dev:tsx:local": "NODE_ENV=local tsx watch src/index.ts",
    "start:staging": "NODE_ENV=staging npm run build && npm start",
    "start:prod": "NODE_ENV=production npm run build && npm start",
    "start:docker": "NODE_ENV=production node dist/index.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "deploy": "npm run build && npm start",
    "deploy:staging": "npm run start:staging",
    "deploy:prod": "npm run start:prod",
    "docker:build": "docker build -t goldenrace-server .",
    "docker:run": "docker run -p 3000:3000 goldenrace-server",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "logs": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log",
    "health": "curl -f http://localhost:3000/api/health || exit 1",
    "health:detailed": "curl -f http://localhost:3000/api/health/detailed || exit 1",
    "reset": "npm run clean && npm install && npm run build",
    "setup": "npm install && echo '환경변수 파일을 생성해주세요: .env'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "express",
    "typescript",
    "supabase",
    "kra",
    "horse-racing",
    "api"
  ],
  "author": "Golden Race Team",
  "license": "MIT"
}
