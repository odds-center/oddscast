{
  "expo": {
    "name": "GoldenRace",
    "slug": "goldenrace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.goldenrace.app",
      "displayName": "GoldenRace",
      "supportsTablet": true,
      "jsEngine": "hermes",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "앱 서비스 알림을 받으려면 권한이 필요합니다.",
        "UIBackgroundModes": ["remote-notification"],
        "aps-environment": "development",
        "FirebaseAppDelegateProxyEnabled": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "goldenrace",
            "CFBundleURLSchemes": ["goldenrace"]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.team-identifier": "F7PXG2W4M9",
        "aps-environment": "development"
      },
      "googleServicesFile": "./google_ios_dev.plist",
      "notification": {
        "icon": "./assets/images/icon.png",
        "color": "#ffffff",
        "iosDisplayInForeground": true,
        "foregroundPresentation": {
          "badge": true,
          "sound": true,
          "banner": true,
          "list": true
        }
      },
      "version": "1.0.0",
      "buildNumber": "1",
      "associatedDomains": ["applinks:goldenrace.app"]
    },
    "android": {
      "versionCode": 1,
      "versionName": "1.0.0",
      "package": "com.goldenrace.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "jsEngine": "hermes",
      "useNextNotificationsApi": true,
      "permissions": ["NOTIFICATIONS", "POST_NOTIFICATIONS", "RECEIVE_BOOT_COMPLETED", "VIBRATE"],
      "googleServicesFile": "./google_android_dev.json",
      "notification": {
        "icon": "./assets/images/icon.png",
        "color": "#ffffff",
        "androidMode": "default",
        "androidCollapsedTitle": true,
        "androidShowInForeground": true,
        "priority": "high",
        "channelId": "default",
        "iconColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "goldenrace"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "androidMode": "default",
          "androidCollapsedTitle": true,
          "iosDisplayInForeground": true,
          "sounds": [],
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "df66e1e3-4e6f-4415-bb26-006a1c34fba0"
      }
    },
    "owner": "indinity",
    "updates": {
      "enabled": true,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "scheme": "goldenrace"
  }
}
