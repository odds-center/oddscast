# ============================================
# Golden Race Server 환경 변수
# ============================================
# .env.example을 .env로 복사 후 값 설정

# PostgreSQL 연결 문자열 (Prisma)
# Supabase: Connection string (Direct) 또는 (Pooler)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# 서버 포트
PORT=3001

# Google OAuth (구글 로그인)
# Google Cloud Console에서 Web Client ID 발급
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Google Gemini API (AI 예측)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# JWT 시크릿 (토큰 서명용)
# openssl rand -base64 32 로 생성 가능
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Redis (캐시 — 선택, 미설정 시 인메모리 캐시 사용)
# REDIS_URL=redis://localhost:6379
