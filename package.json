{
  "name": "goldenrace",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm run --parallel dev:server dev:webapp",
    "setup": "bash scripts/setup.sh",
    "dev:server": "pnpm --filter server dev",
    "dev:webapp": "pnpm --filter webapp dev",
    "dev:admin": "pnpm --filter oddscast-admin dev",
    "build": "pnpm run build:server && pnpm run build:webapp && pnpm run build:admin",
    "build:server": "pnpm --filter server build",
    "build:webapp": "pnpm --filter webapp build",
    "build:admin": "pnpm --filter oddscast-admin build"
  },
  "description": "Golden Race monorepo — pnpm 워크스페이스",
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9",
      "minimatch": ">=10.2.5",
      "multer": ">=2.1.1"
    }
  }
}
