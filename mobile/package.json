{
  "name": "app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --port 3006 --clear",
    "start:dev": "expo start --port 3006 --clear --dev-client",
    "start:fast": "expo start --port 3006 --clear --reset-cache",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "clean": "npx expo install --fix && npx expo start --clear --reset-cache"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@goldenrace/shared": "file:../shared",
    "@react-native-google-signin/google-signin": "^15.0.0",
    "@react-navigation/native": "^7.1.6",
    "expo": "~53.0.23",
    "expo-constants": "~17.1.7",
    "expo-dev-client": "^5.2.4",
    "expo-router": "~5.1.7",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "react": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-webview": "^13.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@types/react": "~19.0.10",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~9.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "typescript": "~5.8.3"
  },
  "private": true
}
