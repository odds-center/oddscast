generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 스키마 전략: 마이그레이션 없음, schema가 default state
// - prisma db push: schema → DB 반영
// - prisma/seed.sql: 초기 데이터 (PointConfig, PointTicketPrice, SubscriptionPlan, GlobalConfig)
// ============================================

// ============================================
// 사용자 (User)
// ============================================
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String
  nickname        String?
  avatar          String?
  role            UserRole  @default(USER)
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  favorites              Favorite[]
  notifications          Notification[]
  notificationPreference UserNotificationPreference?
  predictionTickets PredictionTicket[]
  subscriptions     Subscription[]
  billingHistories  BillingHistory[]
  singlePurchases   SinglePurchase[]
  pointTransactions PointTransaction[]
  bets              Bet[]
  picks             UserPick[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ============================================
// 경기 (Race)
// ============================================
model Race {
  id          String     @id @default(uuid())
  raceName    String?
  meet        String // 서울/부산/제주 코드
  meetName    String? // 서울, 부산경남, 제주
  rcDate      String // YYYYMMDD
  rcNo        String // 경주 번호
  rcDist      String? // 거리
  rcGrade     String? // 등급
  rcCondition String? // 조건
  rcPrize     Int? // 상금
  weather     String?
  trackState  String? // 주로 상태
  status      RaceStatus @default(SCHEDULED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  entries     RaceEntry[]
  results     RaceResult[]
  predictions Prediction[]
  bets        Bet[]
  picks       UserPick[]

  @@unique([meet, rcDate, rcNo])
  @@map("races")
}

enum RaceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// 출전마 (RaceEntry)
// ============================================
model RaceEntry {
  id       String  @id @default(uuid())
  raceId   String
  hrNo     String // 마번 (등록번호)
  hrName   String // 마명
  hrNameEn String? // 영문 마명
  jkNo     String? // 기수 번호
  jkName   String // 기수명
  jkNameEn String? // 영문 기수명
  trNo     String? // 조교사 번호
  trName   String? // 조교사명
  owNo     String? // 마주 번호
  owName   String? // 마주명

  weight Float? // 부담 중량 (wgBudam)
  rating Float? // 레이팅

  chulNo Int? // 출전번호
  dusu   Int? // 총 두수 (해당 경주)

  sex    String? // 성별 (암/수/거)
  age    Int? // 연령
  origin String? // 산지 (국산/외산) - prd

  // 추가 정보 (상금, 통산 성적 등)
  prize1    Int? // 1착 상금 (chaksun1)
  prizeT    BigInt? // 통산 수득 상금 (chaksunT)
  totalRuns Int? // 통산 출전 횟수 (rcCntT)
  totalWins Int? // 통산 1위 횟수 (ord1CntT)

  // 분석용 데이터 (Group B)
  recentRanks    Json?   // 최근 등수 배열
  trainingData   Json?   // 훈련 내역 (JSON) - Simple storage
  equipment      String? // 장구 변경 내역 (KRA API24)
  horseWeight    String? // 마체중 (KRA API25, e.g. "502(-2)")
  bleedingInfo   Json?   // 폐출혈 이력 (bleCnt, bleDate, medicalInfo)
  isScratched    Boolean @default(false) // 출전취소 (KRA API9)

  // Relations
  race      Race       @relation(fields: [raceId], references: [id], onDelete: Cascade)
  trainings Training[] // 1:N Relation with Training data

  @@map("race_entries")
}

// ============================================
// 훈련 데이터 (Training)
// ============================================
model Training {
  id          String  @id @default(uuid())
  raceEntryId String? // Optional link to a specific race entry
  horseNo     String // 마번 (Link to Horse conceptually)

  date           String // 훈련 일자 (YYYYMMDD)
  place          String? // 훈련 장소
  weather        String? // 날씨
  trackCondition String? // 주로 상태

  course    String? // 코스
  time      String? // 훈련 시간 (초/분) or Text
  intensity String? // 훈련 강도

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  raceEntry RaceEntry? @relation(fields: [raceEntryId], references: [id])

  @@index([horseNo])
  @@map("trainings")
}

// ============================================
// 경주 결과 (RaceResult)
// ============================================
model RaceResult {
  id               String  @id @default(uuid())
  raceId           String
  ord              String? // 순서
  hrNo             String // 마번
  hrName           String // 마명
  jkName           String? // 기수명
  trName           String? // 조교사명
  owName           String? // 마주명
  rcRank           String? // 착순
  rcTime           String? // 기록 시간
  rcPrize          Int? // 상금
  rcDist           String? // 거리
  rcGrade          String? // 등급
  rcCondition      String? // 조건
  rcDay            String?
  rcWeekday        String?
  rcWeather        String?
  rcTrack          String?
  rcTrackCondition String?

  // New API Fields
  chulNo  String? // 출전번호
  age     String? // 연령
  sex     String? // 성별
  jkNo    String? // 기수번호
  wgBudam Float? // 부담중량
  wgHr    String? // 마체중 (e.g. 502(-2))
  hrTool  String? // 장구내역

  diffUnit String? // 착차
  winOdds  Float? // 단승식 배당률
  plcOdds  Float? // 복승식 배당률

  sectionalTimes Json? // 구간별 기록 (S1F, G3F, G1F etc.)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@map("race_results")
}

// ============================================
// 기수 통산 전적 (JockeyResult)
// ============================================
model JockeyResult {
  id     String @id @default(uuid())
  meet   String // 1:서울, 2:제주, 3:부경
  jkNo   String // 기수번호
  jkName String // 기수명

  rcCntT   Int // 통산총출전횟수
  ord1CntT Int // 통산1착횟수
  ord2CntT Int // 통산2착횟수
  ord3CntT Int // 통산3착횟수

  winRateTsum Float // 승률
  quRateTsum  Float // 복승률

  chaksunT BigInt // 착순상금 (Total Prize)

  updatedAt DateTime @updatedAt

  @@unique([meet, jkNo])
  @@map("jockey_results")
}

// ============================================
// AI 예측 (Prediction)
// ============================================
model Prediction {
  id              String           @id @default(uuid())
  raceId          String
  scores          Json? // { horseScores: [...] }
  analysis        String?          @db.Text // AI 분석글
  preview         String?          @db.Text // 무료 미리보기
  previewApproved Boolean          @default(false) // 검수 완료 시에만 preview 반환
  accuracy        Float?
  status          PredictionStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  race    Race               @relation(fields: [raceId], references: [id], onDelete: Cascade)
  tickets PredictionTicket[]

  @@map("predictions")
}

enum PredictionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// 예측권 (PredictionTicket)
// ============================================
model PredictionTicket {
  id             String       @id @default(uuid())
  userId         String
  subscriptionId String?
  predictionId   String?
  raceId         String?
  status         TicketStatus @default(AVAILABLE)
  usedAt         DateTime?
  issuedAt       DateTime     @default(now())
  expiresAt      DateTime

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  prediction   Prediction?   @relation(fields: [predictionId], references: [id])

  @@map("prediction_tickets")
}

enum TicketStatus {
  AVAILABLE
  USED
  EXPIRED
}

// ============================================
// 구독 플랜 (SubscriptionPlan)
// ============================================
model SubscriptionPlan {
  id            String   @id @default(uuid())
  planName      String   @unique // LIGHT, PREMIUM
  displayName   String
  description   String?
  originalPrice Int
  vat           Int
  totalPrice    Int
  baseTickets   Int
  bonusTickets  Int
  totalTickets  Int
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

// ============================================
// 구독 (Subscription)
// ============================================
model Subscription {
  id              String             @id @default(uuid())
  userId          String
  planId          String
  price           Int
  status          SubscriptionStatus @default(PENDING)
  billingKey      String?
  nextBillingDate DateTime?
  lastBilledAt    DateTime?
  startedAt       DateTime           @default(now())
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan    SubscriptionPlan   @relation(fields: [planId], references: [id])
  tickets PredictionTicket[]

  @@map("subscriptions")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
}

// ============================================
// 알림 (Notification)
// ============================================
model Notification {
  id        String               @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType     @default(SYSTEM)
  category  NotificationCategory @default(GENERAL)
  isRead    Boolean              @default(false)
  data      Json? // 추가 데이터
  readAt    DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  SYSTEM
  RACE
  PREDICTION
  PROMOTION
  SUBSCRIPTION
}

enum NotificationCategory {
  GENERAL
  URGENT
  INFO
  MARKETING
}

// ============================================
// 알림 설정 (UserNotificationPreference)
// ============================================
model UserNotificationPreference {
  id                 String   @id @default(uuid())
  userId              String   @unique
  pushEnabled         Boolean  @default(true)
  raceEnabled         Boolean  @default(true)   // 경주 시작/결과
  predictionEnabled   Boolean  @default(true)   // AI 예측권/분석 관련
  subscriptionEnabled Boolean  @default(true)   // 구독 결제/만료
  systemEnabled       Boolean  @default(true)   // 시스템 공지
  promotionEnabled    Boolean  @default(false)  // 프로모션/마케팅
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

// ============================================
// 즐겨찾기 (Favorite)
// ============================================
model Favorite {
  id              String           @id @default(uuid())
  userId          String
  type            FavoriteType
  targetId        String
  targetName      String
  targetData      Json?
  memo            String?
  priority        FavoritePriority @default(MEDIUM)
  tags            String[]         @default([])
  notificationsOn Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, targetId])
  @@map("favorites")
}

enum FavoriteType {
  HORSE
  JOCKEY
  TRAINER
  RACE
  MEET
}

enum FavoritePriority {
  LOW
  MEDIUM
  HIGH
}

// ============================================
// 결제 이력 (BillingHistory)
// ============================================
model BillingHistory {
  id              String        @id @default(uuid())
  userId          String
  amount          Int
  billingDate     DateTime      @default(now())
  status          PaymentStatus @default(SUCCESS)
  pgProvider      String?
  pgTransactionId String?
  errorMessage    String?
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billing_histories")
}

enum PaymentStatus {
  SUCCESS
  FAILED
  REFUNDED
}

// ============================================
// 개별 구매 (SinglePurchase)
// ============================================
model SinglePurchase {
  id              String   @id @default(uuid())
  userId          String
  quantity        Int
  totalAmount     Int
  paymentMethod   String?
  pgTransactionId String?
  purchasedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("single_purchases")
}

// ============================================
// 포인트 (Point)
// ============================================
model PointTransaction {
  id              String               @id @default(uuid())
  userId          String
  transactionType PointTransactionType
  amount          Int
  balanceAfter    Int
  description     String
  status          PointStatus          @default(ACTIVE)
  metadata        Json?
  transactionTime DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

model PointPromotion {
  id          String        @id @default(uuid())
  name        String
  description String
  type        PromotionType
  points      Int
  conditions  Json?
  startDate   DateTime
  endDate     DateTime
  maxUses     Int?
  currentUses Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("point_promotions")
}

enum PointTransactionType {
  EARNED
  SPENT
  REFUNDED
  BONUS
  PROMOTION
  ADMIN_ADJUSTMENT
  EXPIRED
  TRANSFER_IN
  TRANSFER_OUT
}

enum PointStatus {
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
  PROCESSING
}

enum PromotionType {
  SIGNUP_BONUS
  REFERRAL_BONUS
  DAILY_LOGIN
  SPECIAL_EVENT
  CUSTOM
}

// ============================================
// 베팅 (Bet)
// ============================================
model Bet {
  id              String    @id @default(uuid())
  userId          String
  raceId          String
  betType         BetType
  betName         String
  betDescription  String?
  betAmount       Int
  potentialWin    Int?
  odds            Float?
  selections      Json // { horses: [], positions: [], combinations: [] }
  betStatus       BetStatus @default(PENDING)
  betResult       BetResult @default(PENDING)
  betTime         DateTime  @default(now())
  raceTime        DateTime?
  resultTime      DateTime?
  actualWin       Int?
  actualOdds      Float?
  confidenceLevel Float?
  betReason       String?
  analysisData    Json?
  apiVersion      String?
  dataSource      String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  roi             Float?
  riskLevel       String?
  isFavorite      Boolean   @default(false)
  notes           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@map("bets")
}

model BetSlip {
  id          String        @id @default(uuid())
  raceId      String
  userId      String
  bets        Json // Array of bets
  totalAmount Int
  status      BetSlipStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("bet_slips")
}

enum BetType {
  WIN
  PLACE
  QUINELLA
  QUINELLA_PLACE
  EXACTA
  TRIFECTA
  TRIPLE
}

enum BetStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  WON
  LOST
}

enum BetResult {
  PENDING
  WIN
  LOSE
  PARTIAL_WIN
  VOID
}

enum BetSlipStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

// ============================================
// 내가 고른 말 (UserPick) — 승식별 기록, 적중 시 포인트
// ============================================
model UserPick {
  id             String   @id @default(uuid())
  userId         String
  raceId         String
  pickType       PickType @default(SINGLE) // 단승/복승/연승/쌍승 등
  hrNos          String[] // 고른 마번 배열 [1, 5] or [1, 5, 7]
  hrNames        String[] // 마명 (표시용)
  pointsAwarded  Int?     @default(0) // 적중 시 지급된 포인트
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@unique([userId, raceId])
  @@map("user_picks")
}

enum PickType {
  SINGLE       // 단승식: 1마리 1등
  PLACE       // 복승식: 1마리 1~3등
  QUINELLA    // 연승식: 2마리 1·2등 (순서 무관)
  EXACTA      // 쌍승식: 2마리 1·2등 (순서 유관)
  QUINELLA_PLACE  // 복연승식: 2마리 3등 이내
  TRIFECTA    // 삼복승식: 3마리 1·2·3등 (순서 무관)
  TRIPLE      // 삼쌍승식: 3마리 1·2·3등 (순서 유관)
}

// ============================================
// 포인트 지급 설정 (PointConfig)
// ============================================
model PointConfig {
  id          String   @id @default(uuid())
  configKey   String   @unique // BASE_POINTS, SINGLE_MULTIPLIER 등
  configValue String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("point_configs")
}

// ============================================
// 포인트 예측권 가격 (PointTicketPrice)
// ============================================
model PointTicketPrice {
  id               String    @id @default(uuid())
  pointsPerTicket  Int       // 1장당 포인트 (예: 1200)
  isActive         Boolean   @default(true)
  effectiveFrom    DateTime  @default(now())
  effectiveTo      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("point_ticket_prices")
}

// ============================================
// KRA API 동기화 로그 (각 API 호출 이력)
// ============================================
model KraSyncLog {
  id           String   @id @default(uuid())
  endpoint     String   // API 엔드포인트 (entrySheet, raceResult, jockey, trackInfo 등)
  meet         String?  // 경마장 코드 (1/2/3)
  rcDate       String?  // YYYYMMDD
  status       String   // SUCCESS, FAILED, PARTIAL
  recordCount  Int      @default(0) // 처리된 레코드 수
  errorMessage String?  @db.Text
  durationMs   Int?     // 소요 시간 (ms)
  createdAt    DateTime @default(now())

  @@index([endpoint, rcDate])
  @@index([createdAt])
  @@map("kra_sync_logs")
}

// ============================================
// 글로벌 설정 (Key-Value, NoSQL 스타일)
// ============================================
model GlobalConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // JSON 문자열 또는 단순 문자열
  updatedAt DateTime @updatedAt

  @@map("global_config")
}
