{
  "name": "goldenrace-server",
  "version": "1.0.0",
  "description": "Golden Race NestJS Server for KRA API integration",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "dev": "./scripts/start.sh",
    "start:docker": "./scripts/start-docker.sh",
    "docker:start": "./scripts/start-docker.sh",
    "db:init": "./scripts/init-db.sh",
    "db:setup": "docker-compose exec -T mysql mysql -u root -prootpassword < mysql/init/00_setup_user.sql",
    "db:reset": "docker-compose exec -T mysql mysql -u goldenrace_user -pgoldenrace_password goldenrace < mysql/init/01_create_database.sql",
    "db:drop": "docker-compose exec -T mysql mysql -u root -prootpassword -e 'DROP DATABASE IF EXISTS goldenrace;'",
    "db:create": "docker-compose exec -T mysql mysql -u root -prootpassword -e 'CREATE DATABASE IF NOT EXISTS goldenrace CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;'",
    "db:status": "docker-compose exec -T mysql mysql -u goldenrace_user -pgoldenrace_password -e 'SHOW TABLES;' goldenrace",
    "db:full-reset": "npm run db:drop && npm run db:create && npm run db:setup && npm run db:reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:mysql": "docker-compose -f docker-compose.mysql-only.yml up -d",
    "docker:mysql:stop": "docker-compose -f docker-compose.mysql-only.yml down",
    "docker:rebuild": "docker-compose up -d --build",
    "docker:clean": "docker-compose down --remove-orphans && docker system prune -f",
    "docker:build": "docker build -t goldenrace-server:dev .",
    "db:logs": "docker-compose logs -f mysql",
    "init:data": "ts-node -r tsconfig-paths/register scripts/init-historical-data.ts",
    "init:data:30days": "ts-node -r tsconfig-paths/register scripts/init-historical-data.ts --days=30",
    "init:data:year": "ts-node -r tsconfig-paths/register scripts/init-historical-data.ts --year=2024",
    "init:plans": "ts-node -r tsconfig-paths/register scripts/init-subscription-plans.ts",
    "init:data:check": "ts-node -r tsconfig-paths/register scripts/init-historical-data.ts --check",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/typeorm": "^10.0.1",
    "@tosspayments/payment-sdk": "^1.9.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/moment": "^2.13.0",
    "@types/moment-timezone": "^0.5.30",
    "@types/uuid": "^10.0.0",
    "axios": "^1.6.0",
    "bignumber.js": "^9.3.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "es-toolkit": "^1.39.10",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "mysql2": "^3.6.5",
    "openai": "^6.3.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "qs": "^6.14.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "keywords": [
    "nestjs",
    "typescript",
    "mysql",
    "kra",
    "horse-racing",
    "api"
  ],
  "author": "Golden Race Team",
  "license": "MIT"
}
