{
  "name": "app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "react-native start --port 3006",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "react-native start --reset-cache",
    "start:dev": "ENVFILE=.env.dev react-native start --port 3006",
    "start:prod": "ENVFILE=.env.prod react-native start --port 3006",
    "build:android": "./scripts/build-android.sh apk",
    "build:android:apk": "./scripts/build-android.sh apk",
    "build:android:bundle": "./scripts/build-android.sh bundle",
    "build:android:clean": "./scripts/build-android.sh clean",
    "build:android:dev": "ENVFILE=.env.dev ./scripts/build-android.sh apk",
    "build:android:prod": "ENVFILE=.env.prod ./scripts/build-android.sh apk",
    "build:android:prod:bundle": "ENVFILE=.env.prod ./scripts/build-android.sh bundle",
    "build:ios": "./scripts/build-ios.sh simulator",
    "build:ios:device": "./scripts/build-ios.sh device",
    "build:ios:archive": "./scripts/build-ios.sh archive",
    "build:ios:clean": "./scripts/build-ios.sh clean",
    "build:ios:dev": "ENVFILE=.env.dev ./scripts/build-ios.sh device",
    "build:ios:prod": "ENVFILE=.env.prod ./scripts/build-ios.sh archive"
  },
  "dependencies": {
    "@oddscast/shared": "file:../shared",
    "@react-native-firebase/app": "^21.6.1",
    "@react-native-firebase/messaging": "^21.6.1",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@sentry/react-native": "^8.3.0",
    "react": "19.0.0",
    "react-native": "0.79.5",
    "react-native-config": "^1.6.1",
    "react-native-device-info": "^14.0.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-vector-icons": "^10.2.0",
    "react-native-webview": "^13.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@react-native-community/cli": "19.1.2",
    "@react-native-community/cli-platform-ios": "19.0.0",
    "@react-native/babel-preset": "0.79.5",
    "@react-native/eslint-config": "0.79.5",
    "@react-native/metro-config": "0.79.5",
    "@react-native/typescript-config": "0.79.5",
    "@types/react": "^19.2.0",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
